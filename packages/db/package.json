{
  "name": "@caseprac/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.mjs",
      "require": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/schema.ts --format cjs,esm --dts --shims",
    "dev": "tsup src/index.ts src/schema.ts --format cjs,esm --dts --shims --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts",
    "clean": "rm -rf dist .drizzle"
  },
  "dependencies": {
    "@caseprac/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@caseprac/config": "workspace:*",
    "@types/node": "^22.10.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
