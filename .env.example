# Environment Configuration
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# PostgreSQL Database
DATABASE_URL=postgres://caseprac:caseprac_password@localhost:5432/caseprac_db

# Redis & BullMQ
REDIS_URL=redis://localhost:6379

# Object Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=caseprac-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Authentication & GitHub OAuth
JWT_SECRET=super-secret-jwt-key-caseprac-dev-change-in-production
GITHUB_CLIENT_ID=mock_github_client_id
GITHUB_CLIENT_SECRET=mock_github_client_secret

# Runner & Evaluation Settings
RUNNER_CONCURRENCY=2
EVAL_TIMEOUT_MS=120000
